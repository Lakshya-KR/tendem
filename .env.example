# Copy this file to .env and fill in your values.
# No real secrets should ever be committed to the repository.

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- OpenAI-compatible (Hermes provider) ---
# If unset, these fall back to the OpenRouter values above.
OPENAI_API_KEY=your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Apify (data) ---
APIFY_TOKEN=your-apify-token-here
APIFY_BASE_URL=https://api.apify.com/v2

# --- Prediction markets ---
KALSHI_BASE_URL=https://api.kalshi.com/trade-api/v2
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com

# --- Pipeline ---
PREDICTION_HISTORY_PATH=./examples/prediction_history.jsonl
LOG_LEVEL=INFO

# --- Kronos (forecasting) ---
# KRONOS=on (default) tries scripts/kronos_infer.py first, falls back to LLM proxy.
# KRONOS=off skips the subprocess entirely.
KRONOS=on
# Override the default path if you installed Kronos elsewhere:
# KRONOS_SCRIPT_PATH=/absolute/path/to/predict.py
